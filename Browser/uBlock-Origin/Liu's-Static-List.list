||tiles.services.mozilla.com^$domain=behind-the-scene

! TWITTER
||platform.twitter.com/widgets.js$third-party

! WEIBO
||widget.weibo.com^$important,third-party

! Other
||jsjb.cc^$third-party
||huluxia.com^$third-party,~image

